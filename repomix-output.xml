import { notFound } from "next/navigation";
import Image from "next/image";
import Link from "next/link";
import { ArrowLeft } from "lucide-react";
import Header from "@/components/Header";
import Footer from "@/components/Footer";
import ShareButton from "@/components/ShareButton";
import { Metadata } from "next";
import { client } from "@/sanity/lib/client";
import { PortableText } from "@portabletext/react";

// 1. Helper to calculate read time from Sanity blocks
function calculateReadTime(blocks: any[]): string {
    if (!blocks || blocks.length === 0) return "1 min read";
    const text = blocks
        .filter((block) => block._type === "block" && block.children)
        .map((block) => block.children.map((child: any) => child.text).join(""))
        .join(" ");
    const wordCount = text.trim().split(/\s+/).length;
    return `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
}

// 2. SEO Metadata Generation
export async function generateMetadata({ params }: { params: Promise<{ id: string }> }): Promise<Metadata> {
    const resolvedParams = await params;
    const insight = await client.fetch(`*[_type == "insight" && slug.current == $id][0]{ title, summary }`, {
        id: resolvedParams.id
    });

    if (!insight) return { title: "Insight Not Found" };
    return {
        title: `${insight.title} | The Marque`,
        description: insight.summary,
    };
}

// 3. Static Generation for instant page loads
export async function generateStaticParams() {
    const insights = await client.fetch(`*[_type == "insight" && defined(slug.current)]{
    "id": slug.current
  }`);
    return insights.map((insight: { id: string }) => ({ id: insight.id }));
}

// 4. Define how custom Sanity blocks map to your Tailwind UI!
const portableTextComponents = {
    types: {
        // This perfectly matches the "quoteBlock" we defined in the Sanity schema
        quoteBlock: ({ value }: any) => (
            <blockquote className="border-l-4 border-graphite pl-6 py-2 my-10 bg-white shadow-sm p-6 rounded-r-sm">
                <p className="text-2xl font-serif text-graphite italic leading-snug">
                    "{value.quote}"
                </p>
            </blockquote>
        ),
    },
    block: {
        // Adds proper spacing to standard paragraphs
        normal: ({ children }: any) => <p className="mb-6">{children}</p>,
    },
};

// 5. The Server Component
export default async function InsightPage({ params }: { params: Promise<{ id: string }> }) {
    const resolvedParams = await params;

    // Fetch the full article from Sanity
    const insight = await client.fetch(`*[_type == "insight" && slug.current == $id][0]{
    title,
    category,
    author,
    "image": image.asset->url,
    content
  }`, { id: resolvedParams.id });

    if (!insight) notFound();

    const readTime = calculateReadTime(insight.content);

    return (
        <>
            <Header />
            <main className="min-h-screen bg-cream pb-24">

                {/* Full Width Hero */}
                <div className="relative w-full h-[60vh] min-h-[400px] bg-graphite flex items-end">
                    <Image
                        src={insight.image}
                        alt={insight.title}
                        fill
                        priority
                        className="object-cover"
                        sizes="100vw"
                    />
                    <div className="absolute inset-0 bg-gradient-to-t from-[#1A1B1A] via-[#1A1B1A]/60 to-transparent" />

                    <div className="relative z-10 max-w-4xl mx-auto px-6 lg:px-10 w-full pb-16">
                        <Link href="/insights" className="inline-flex items-center gap-2 text-cream/60 hover:text-copper transition-colors text-sm font-medium mb-8">
                            <ArrowLeft size={16} /> Back to Insights
                        </Link>

                        <div className="flex items-center gap-3 mb-6">
                            <span className="bg-copper text-white text-[10px] font-bold tracking-widest uppercase px-3 py-1 rounded-sm">
                                {insight.category}
                            </span>
                            <span className="text-cream/60 text-sm font-medium">{readTime}</span>
                        </div>

                        <h1 className="text-3xl md:text-5xl lg:text-6xl font-bold text-cream leading-[1.1] tracking-tight mb-6">
                            {insight.title}
                        </h1>

                        <p className="text-copper font-medium">By {insight.author}</p>
                    </div>
                </div>

                {/* Single Column Editorial Layout */}
                <article className="max-w-3xl mx-auto px-6 lg:px-10 pt-16">
                    <div className="text-lg text-graphite/80 leading-relaxed font-light">
                        {/* The PortableText component automatically renders the rich text using our custom UI mapping */}
                        <PortableText value={insight.content} components={portableTextComponents} />
                    </div>

                    {/* Share/Action Bar */}
                    <div className="mt-16 pt-8 border-t border-graphite/10 flex justify-between items-center">
                        <p className="text-sm text-graphite font-bold tracking-widest uppercase">The Marque Editorial</p>
                        <ShareButton title={insight.title} />
                    </div>
                </article>

            </main>
            <Footer />
        </>
    );
}
